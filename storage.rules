rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource != null && request.resource.contentType.matches('image/.*');
    }

    function isVideo() {
      return request.resource != null && request.resource.contentType.matches('video/.*');
    }

    function under10MB() {
      return request.resource != null && request.resource.size < 10 * 1024 * 1024;
    }

    function under200MB() {
      return request.resource != null && request.resource.size < 200 * 1024 * 1024;
    }

    match /issue_photos/{uid}/{issueId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid && isImage() && under10MB();
    }

    match /checklist_photos/{uid}/{runId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid && isImage() && under10MB();
    }

    match /issue_videos/{uid}/{issueId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid && ((isVideo() && under200MB()) || (isImage() && under10MB()));
    }

    match /comment_photos/{uid}/{issueId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid && isImage() && under10MB();
    }

    match /profile_photos/{uid}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid && isImage() && under10MB();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
